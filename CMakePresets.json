{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_CXX_SCAN_FOR_MODULES": "OFF",
                "CPM_SOURCE_CACHE": "${sourceDir}/.cache/cpm"
            }
        },
        {
            "name": "unix-base",
            "hidden": true,
            "inherits": "base",
            "condition": {
                "type": "anyOf",
                "conditions": [
                    { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Linux" },
                    { "type": "equals", "lhs": "${hostSystemName}", "rhs": "Darwin" }
                ]
            }
        },
        {
            "name": "clang-debug",
            "inherits": "unix-base",
            "displayName": "Clang Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_CLANG_TIDY": "ON",
                "ENABLE_ASAN": "ON",
                "ENABLE_UBSAN": "ON"
            }
        },
        {
            "name": "clang-release",
            "inherits": "unix-base",
            "displayName": "Clang Release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++"
            }
        },
        {
            "name": "clang-coverage",
            "inherits": "unix-base",
            "displayName": "Clang Coverage",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_CXX_COMPILER": "clang++",
                "ENABLE_COVERAGE": "ON"
            }
        },
        {
            "name": "gcc-debug",
            "inherits": "unix-base",
            "displayName": "GCC Debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_COMPILER": "gcc",
                "CMAKE_CXX_COMPILER": "g++"
            }
        }
    ],
    "buildPresets": [
        { "name": "clang-debug", "configurePreset": "clang-debug" },
        { "name": "clang-release", "configurePreset": "clang-release" },
        { "name": "clang-coverage", "configurePreset": "clang-coverage" },
        { "name": "gcc-debug", "configurePreset": "gcc-debug" }
    ],
    "testPresets": [
        {
            "name": "clang-debug",
            "configurePreset": "clang-debug",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "clang-release",
            "configurePreset": "clang-release",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "clang-coverage",
            "configurePreset": "clang-coverage",
            "output": { "outputOnFailure": true }
        },
        {
            "name": "gcc-debug",
            "configurePreset": "gcc-debug",
            "output": { "outputOnFailure": true }
        }
    ]
}
